"``data_format``:"

#: ../../source/base-storage-api-v2.rst:236
msgid ""
"# 跳过前 100 行\n"
"reader = arrow_client.read_rows_arrow(\n"
"    read_resp.session_id,\n"
"    split_index=0,\n"
"    skip_row_num=100,\n"
")\n"
