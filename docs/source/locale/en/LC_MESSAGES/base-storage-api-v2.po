"reader = arrow_client.read_rows_arrow(\n"
"    read_resp.session_id,\n"
"    split_index=0,\n"
"    max_batch_raw_size=8 * 1024 * 1024,\n"
")"

#: ../../source/base-storage-api-v2.rst:233
