"    read_resp.session_id,\n"
"    split_index=0,\n"
"    data_columns=[\"id\", \"name\"],\n"
")"
msgstr ""
"# Skip the first 100 rows\n"
"reader = arrow_client.read_rows_arrow(\n"
"    read_resp.session_id,\n"
"    split_index=0,\n"
"    skip_row_num=100,\n"
")\n"
"\n"
"# Read only specific columns\n"
"reader = arrow_client.read_rows_arrow(\n"
"    read_resp.session_id,\n"
"    split_index=0,\n"
"    data_columns=[\"id\", \"name\"],\n"
")"

#: ../../source/base-storage-api-v2.rst:253
msgid "并行读取数据"
msgstr "Parallel reading"

#: ../../source/base-storage-api-v2.rst:255
msgid "Storage API V2 的分片机制天然支持并行读取。每个分片可以独立读取，适合多线程或多进程场景："
msgstr ""
"The split mechanism of Storage API V2 natively supports parallel reading."
" Each split can be read independently, making it suitable for multi-"
"threaded or multi-process scenarios:"

#: ../../source/base-storage-api-v2.rst:257
msgid ""
"from concurrent.futures import ThreadPoolExecutor\n"
"\n"
"read_resp = arrow_client.create_read_session()\n"
"\n"
"def read_split(split_index):\n"
"    reader = arrow_client.read_rows_arrow(\n"
"        read_resp.session_id, split_index=split_index\n"
"    )\n"
"    batches = []\n"
"    while True:\n"
"        batch = reader.read()\n"
"        if batch is None:\n"
"            break\n"
"        batches.append(batch)\n"
"    return pa.concat_batches(batches) if batches else None\n"
"\n"
"# 使用线程池并行读取所有分片\n"
"with ThreadPoolExecutor(max_workers=read_resp.splits_count) as pool:\n"
"    futures = [\n"
"        pool.submit(read_split, i)\n"
"        for i in range(read_resp.splits_count)\n"
"    ]\n"
"    results = [f.result() for f in futures]"
msgstr ""
"from concurrent.futures import ThreadPoolExecutor\n"
"\n"
"read_resp = arrow_client.create_read_session()\n"
"\n"
"def read_split(split_index):\n"
"    reader = arrow_client.read_rows_arrow(\n"
"        read_resp.session_id, split_index=split_index\n"
"    )\n"
"    batches = []\n"
"    while True:\n"
"        batch = reader.read()\n"
"        if batch is None:\n"
"            break\n"
"        batches.append(batch)\n"
"    return pa.concat_batches(batches) if batches else None\n"
"\n"
"# Read all splits in parallel using a thread pool\n"
"with ThreadPoolExecutor(max_workers=read_resp.splits_count) as pool:\n"
"    futures = [\n"
"        pool.submit(read_split, i)\n"
"        for i in range(read_resp.splits_count)\n"
"    ]\n"
"    results = [f.result() for f in futures]"

#: ../../source/base-storage-api-v2.rst:284
msgid "刷新读会话"
msgstr "Refreshing a read session"

#: ../../source/base-storage-api-v2.rst:286
msgid ""
"读会话有过期时间。如果在长时间读取过程中会话过期，可以使用 ``get_read_session`` 的 ``refresh`` "
"参数延长会话有效期："
msgstr ""
"Read sessions have an expiration time. If a session expires during a "
"long-running read, you can use the ``refresh`` parameter of "
"``get_read_session`` to extend the session lifetime:"

#: ../../source/base-storage-api-v2.rst:289
msgid ""
"from odps.apis.storage_api_v2 import SessionStatus\n"
"\n"
"# 检查会话状态\n"
"status = arrow_client.get_read_session(read_resp.session_id)\n"
"if status.session_status == SessionStatus.EXPIRED:\n"
"    # 刷新会话\n"
"    status = arrow_client.get_read_session(read_resp.session_id, "
"refresh=True)"
msgstr ""
"from odps.apis.storage_api_v2 import SessionStatus\n"
"\n"
"# Check session status\n"
"status = arrow_client.get_read_session(read_resp.session_id)\n"
"if status.session_status == SessionStatus.EXPIRED:\n"
"    # Refresh the session\n"
"    status = arrow_client.get_read_session(read_resp.session_id, "
"refresh=True)"

#: ../../source/base-storage-api-v2.rst:300
msgid "增量读取"
msgstr "Incremental reading"

#: ../../source/base-storage-api-v2.rst:302
msgid "Storage API V2 支持增量读取模式，可以捕获表的数据变更："
msgstr ""
"Storage API V2 supports incremental reading mode to capture table data "
"changes:"

#: ../../source/base-storage-api-v2.rst:304
#, python-brace-format
msgid ""
"from odps.apis.storage_api_v2 import IncrementalReadOptions\n"
"\n"
"incr_opts = IncrementalReadOptions()\n"
"incr_opts.start_version = 100\n"
"read_resp = arrow_client.create_read_session(\n"
"    incremental_read=True,\n"
"    incremental_read_options=incr_opts,\n"
")\n"
"print(f\"当前最新版本: {read_resp.latest_version}\")"
msgstr ""
"from odps.apis.storage_api_v2 import IncrementalReadOptions\n"
"\n"
"incr_opts = IncrementalReadOptions()\n"
"incr_opts.start_version = 100\n"
"read_resp = arrow_client.create_read_session(\n"
"    incremental_read=True,\n"
"    incremental_read_options=incr_opts,\n"
")\n"
"print(f\"Latest version: {read_resp.latest_version}\")"

#: ../../source/base-storage-api-v2.rst:316
msgid "也可以按时间戳范围进行增量读取："
msgstr "You can also perform incremental reading by timestamp range:"

#: ../../source/base-storage-api-v2.rst:318
msgid ""
"incr_opts = IncrementalReadOptions()\n"
"incr_opts.start_time_stamp = \"2023-01-01 00:00:00\"\n"
"incr_opts.end_time_stamp = \"2023-01-02 00:00:00\"\n"
"read_resp = arrow_client.create_read_session(\n"
"    incremental_read=True,\n"
"    incremental_read_options=incr_opts,\n"
")"
msgstr ""
"incr_opts.start_time_stamp = \"2023-01-01 00:00:00\"\n"
"incr_opts.end_time_stamp = \"2023-01-02 00:00:00\"\n"
"read_resp = arrow_client.create_read_session(\n"
"    incremental_read=True,\n"
"    incremental_read_options=incr_opts,\n"
")"

#: ../../source/base-storage-api-v2.rst:329
msgid "从 SQL Instance 读取数据"
msgstr "Reading data from a SQL Instance"

#: ../../source/base-storage-api-v2.rst:331
msgid "Storage API V2 支持从 SQL 执行结果（Instance）中读取数据，此时客户端为只读模式："
msgstr ""
"Storage API V2 supports reading data from SQL execution results "
"(Instance). In this case, the client operates in read-only mode:"

#: ../../source/base-storage-api-v2.rst:333
msgid ""
"# 执行 SQL 获取 Instance\n"
"instance = odps.execute_sql(\"SELECT * FROM your_table LIMIT 1000\")\n"
"\n"
"# 使用 Instance 创建客户端\n"
"instance_client = StorageApiArrowClient(odps, instance)\n"
"read_resp = instance_client.create_read_session()\n"
"\n"
"# 读取结果\n"
"for split_index in range(read_resp.splits_count):\n"
"    reader = instance_client.read_rows_arrow(\n"
"        read_resp.session_id, split_index=split_index\n"
"    )\n"
"    while True:\n"
"        batch = reader.read()\n"
"        if batch is None:\n"
"            break\n"
"        df = batch.to_pandas()"
msgstr ""
"# Execute SQL to get an Instance\n"
"instance = odps.execute_sql(\"SELECT * FROM your_table LIMIT 1000\")\n"
"\n"
"# Create a client with the Instance\n"
"instance_client = StorageApiArrowClient(odps, instance)\n"
"read_resp = instance_client.create_read_session()\n"
"\n"
"# Read the results\n"
"for split_index in range(read_resp.splits_count):\n"
"    reader = instance_client.read_rows_arrow(\n"
"        read_resp.session_id, split_index=split_index\n"
"    )\n"
"    while True:\n"
"        batch = reader.read()\n"
"        if batch is None:\n"
"            break\n"
"        df = batch.to_pandas()"

#: ../../source/base-storage-api-v2.rst:355
msgid "基于 Instance 的客户端不支持写操作。调用写操作方法会抛出 ``ValueError``。"
msgstr ""
"Instance-based clients do not support write operations. Calling write "
"methods will raise a ``ValueError``."

#: ../../source/base-storage-api-v2.rst:358
msgid "预览表数据"
msgstr "Previewing table data"

#: ../../source/base-storage-api-v2.rst:360
msgid "预览功能提供了一种轻量级的数据浏览方式，无需创建会话即可快速查看表数据："
msgstr ""
"The preview feature provides a lightweight way to browse data without "
"creating a session:"

#: ../../source/base-storage-api-v2.rst:362
msgid ""
"from odps.apis.storage_api_v2 import ArrowReader\n"
"\n"
"# 使用 Arrow 客户端预览\n"
"reader = arrow_client.preview_table_arrow(limit=10)\n"
"batch = reader.read()\n"
"if batch is not None:\n"
"    df = batch.to_pandas()\n"
"    print(df)\n"
"\n"
"# 使用基础客户端预览\n"
"stream_reader = client.preview_table(limit=10)\n"
"arrow_reader = ArrowReader(stream_reader)\n"
"batch = arrow_reader.read()\n"
"if batch is not None:\n"
"    df = batch.to_pandas()\n"
"    print(df)"
msgstr ""
"from odps.apis.storage_api_v2 import ArrowReader\n"
"\n"
"# Preview using the Arrow client\n"
"reader = arrow_client.preview_table_arrow(limit=10)\n"
"batch = reader.read()\n"
"if batch is not None:\n"
"    df = batch.to_pandas()\n"
"    print(df)\n"
"\n"
"# Preview using the base client\n"
"stream_reader = client.preview_table(limit=10)\n"
"arrow_reader = ArrowReader(stream_reader)\n"
"batch = arrow_reader.read()\n"
"if batch is not None:\n"
"    df = batch.to_pandas()\n"
"    print(df)"

#: ../../source/base-storage-api-v2.rst:381
msgid "可以指定分区和列进行预览："
msgstr "You can specify partitions and columns for preview:"

#: ../../source/base-storage-api-v2.rst:383
msgid ""
"# 预览指定分区\n"
"reader = arrow_client.preview_table_arrow(limit=10, "
"partition=\"pt=20230101\")\n"
"\n"
"# 预览指定列\n"
"reader = arrow_client.preview_table_arrow(limit=10, columns=[\"id\", "
"\"name\"])"
msgstr ""
"# Preview a specific partition\n"
"reader = arrow_client.preview_table_arrow(limit=10, "
"partition=\"pt=20230101\")\n"
"\n"
"# Preview specific columns\n"
"reader = arrow_client.preview_table_arrow(limit=10, columns=[\"id\", "
"\"name\"])"

#: ../../source/base-storage-api-v2.rst:393
msgid ""
"预览功能仅适用于表，不支持 Instance 客户端。预览返回的行数可能不精确， 生产环境建议使用 ``create_read_session``"
" + ``read_rows_arrow`` 进行精确读取。"
msgstr ""
"The preview feature only works with tables, not Instance clients. The "
"number of rows returned by preview may not be exact. For production use "
"cases requiring precise row counts, use ``create_read_session`` + "
"``read_rows_arrow`` instead."

#: ../../source/base-storage-api-v2.rst:397
#: ../../source/base-storage-api-v2.rst:406
msgid "写入数据"
msgstr "Writing data"

#: ../../source/base-storage-api-v2.rst:400
msgid "完整写入流程"
msgstr "Complete write workflow"

#: ../../source/base-storage-api-v2.rst:402
msgid "使用 Storage API V2 写入数据需要以下步骤："
msgstr "Writing data with Storage API V2 involves the following steps:"

#: ../../source/base-storage-api-v2.rst:404
msgid "创建写会话"
msgstr "Create a write session"

#: ../../source/base-storage-api-v2.rst:405
msgid "创建写流"
msgstr "Create a write stream"

#: ../../source/base-storage-api-v2.rst:407
msgid "关闭写流"
msgstr "Close the write stream"

#: ../../source/base-storage-api-v2.rst:408
msgid "提交写会话"
msgstr "Commit the write session"

#: ../../source/base-storage-api-v2.rst:410
msgid ""
"import pyarrow as pa\n"
"from odps.apis.storage_api_v2 import StorageApiArrowClient\n"
"\n"
"arrow_client = StorageApiArrowClient(odps, table)\n"
"\n"
"# 1. 创建写会话\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"# 2. 创建写流\n"
"stream_resp = arrow_client.create_write_stream(session_id, stream_id=0)\n"
"\n"
"# 3. 写入数据\n"
"schema = pa.schema([\n"
"    pa.field(\"id\", pa.int64()),\n"
"    pa.field(\"name\", pa.string()),\n"
"    pa.field(\"value\", pa.float64()),\n"
"])\n"
"batch = pa.record_batch([\n"
"    pa.array([1, 2, 3]),\n"
"    pa.array([\"Alice\", \"Bob\", \"Carol\"]),\n"
"    pa.array([100.0, 200.0, 150.0]),\n"
"], schema=schema)\n"
"\n"
"writer = arrow_client.write_rows_arrow(\n"
"    session_id, stream_id=0, record_count=3,\n"
")\n"
"writer.write(batch)\n"
"commit_msg, success = writer.finish()\n"
"\n"
"# 4. 关闭写流\n"
"arrow_client.close_write_stream(session_id, stream_id=0)\n"
"\n"
"# 5. 提交写会话\n"
"arrow_client.commit_write_session(session_id)"
msgstr ""
"import pyarrow as pa\n"
"from odps.apis.storage_api_v2 import StorageApiArrowClient\n"
"\n"
"arrow_client = StorageApiArrowClient(odps, table)\n"
"\n"
"# 1. Create a write session\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"# 2. Create a write stream\n"
"stream_resp = arrow_client.create_write_stream(session_id, stream_id=0)\n"
"\n"
"# 3. Write data\n"
"schema = pa.schema([\n"
"    pa.field(\"id\", pa.int64()),\n"
"    pa.field(\"name\", pa.string()),\n"
"    pa.field(\"value\", pa.float64()),\n"
"])\n"
"batch = pa.record_batch([\n"
"    pa.array([1, 2, 3]),\n"
"    pa.array([\"Alice\", \"Bob\", \"Carol\"]),\n"
"    pa.array([100.0, 200.0, 150.0]),\n"
"], schema=schema)\n"
"\n"
"writer = arrow_client.write_rows_arrow(\n"
"    session_id, stream_id=0, record_count=3,\n"
")\n"
"writer.write(batch)\n"
"commit_msg, success = writer.finish()\n"
"\n"
"# 4. Close the write stream\n"
"arrow_client.close_write_stream(session_id, stream_id=0)\n"
"\n"
"# 5. Commit the write session\n"
"arrow_client.commit_write_session(session_id)"

#: ../../source/base-storage-api-v2.rst:449
msgid "写入分区表"
msgstr "Writing to partitioned tables"

#: ../../source/base-storage-api-v2.rst:451
msgid "写入分区表时需要在创建写会话时指定分区："
msgstr ""
"When writing to a partitioned table, specify the partition when creating "
"the write session:"

#: ../../source/base-storage-api-v2.rst:453
msgid ""
"# 写入指定分区\n"
"write_resp = arrow_client.create_write_session(\n"
"    partial_partition_spec=\"pt=20230101\"\n"
")"
msgstr ""
"# Write to a specific partition\n"
"write_resp = arrow_client.create_write_session(\n"
"    partial_partition_spec=\"pt=20230101\"\n"
")"

#: ../../source/base-storage-api-v2.rst:460
msgid "如果需要覆盖已有分区数据，可以使用 ``flags`` 参数："
msgstr "To overwrite existing partition data, use the ``flags`` parameter:"

#: ../../source/base-storage-api-v2.rst:462
#, python-brace-format
msgid ""
"# 覆盖写入分区\n"
"write_resp = arrow_client.create_write_session(\n"
"    partial_partition_spec=\"pt=20230101\",\n"
"    flags={\"overwrite\": True},\n"
")"
msgstr ""
"# Overwrite the partition\n"
"write_resp = arrow_client.create_write_session(\n"
"    partial_partition_spec=\"pt=20230101\",\n"
"    flags={\"overwrite\": True},\n"
")"

#: ../../source/base-storage-api-v2.rst:471
msgid "并行写入数据"
msgstr "Parallel writing"

#: ../../source/base-storage-api-v2.rst:473
msgid "一个写会话可以创建多个写流，支持并行写入："
msgstr ""
"A write session can create multiple write streams to support parallel "
"writing:"

#: ../../source/base-storage-api-v2.rst:475
msgid ""
"from concurrent.futures import ThreadPoolExecutor\n"
"\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"def write_stream(stream_id, data_batch):\n"
"    # 创建写流\n"
"    arrow_client.create_write_stream(session_id, stream_id=stream_id)\n"
"    # 写入数据\n"
"    writer = arrow_client.write_rows_arrow(\n"
"        session_id, stream_id=stream_id, record_count=len(data_batch),\n"
"    )\n"
"    writer.write(data_batch)\n"
"    writer.finish()\n"
"    # 关闭写流\n"
"    arrow_client.close_write_stream(session_id, stream_id=stream_id)\n"
"\n"
"# 多线程并行写入\n"
"with ThreadPoolExecutor(max_workers=3) as pool:\n"
"    futures = [\n"
"        pool.submit(write_stream, i, batch_data[i])\n"
"        for i in range(3)\n"
"    ]\n"
"    [f.result() for f in futures]\n"
"\n"
"# 提交写会话\n"
"arrow_client.commit_write_session(session_id)"
msgstr ""
"from concurrent.futures import ThreadPoolExecutor\n"
"\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"def write_stream(stream_id, data_batch):\n"
"    # Create a write stream\n"
"    arrow_client.create_write_stream(session_id, stream_id=stream_id)\n"
"    # Write data\n"
"    writer = arrow_client.write_rows_arrow(\n"
"        session_id, stream_id=stream_id, record_count=len(data_batch),\n"
"    )\n"
"    writer.write(data_batch)\n"
"    writer.finish()\n"
"    # Close the write stream\n"
"    arrow_client.close_write_stream(session_id, stream_id=stream_id)\n"
"\n"
"# Write in parallel with multiple threads\n"
"with ThreadPoolExecutor(max_workers=3) as pool:\n"
"    futures = [\n"
"        pool.submit(write_stream, i, batch_data[i])\n"
"        for i in range(3)\n"
"    ]\n"
"    [f.result() for f in futures]\n"
"\n"
"# Commit the write session\n"
"arrow_client.commit_write_session(session_id)"

#: ../../source/base-storage-api-v2.rst:506
msgid "使用原始字节流写入数据"
msgstr "Writing data with raw byte streams"

#: ../../source/base-storage-api-v2.rst:508
msgid ""
"使用 ``StorageApiClient`` 的 ``write_rows_stream`` 方法可以获取 ``StreamWriter``， "
"然后使用 ``ArrowWriter`` 包装进行写入："
msgstr ""
"Use the ``write_rows_stream`` method of ``StorageApiClient`` to get a "
"``StreamWriter``, then wrap it with ``ArrowWriter`` for writing:"

#: ../../source/base-storage-api-v2.rst:511
msgid ""
"from odps.apis.storage_api_v2 import StorageApiClient, ArrowWriter, "
"Compression\n"
"\n"
"client = StorageApiClient(odps, table)\n"
"\n"
"write_resp = client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"client.create_write_stream(session_id, stream_id=0)\n"
"\n"
"stream_writer = client.write_rows_stream(\n"
"    session_id, stream_id=0, record_count=3,\n"
")\n"
"arrow_writer = ArrowWriter(stream_writer, Compression.UNCOMPRESSED)\n"
"arrow_writer.write(batch)\n"
"commit_msg, success = arrow_writer.finish()\n"
"\n"
"client.close_write_stream(session_id, stream_id=0)\n"
"client.commit_write_session(session_id)"
msgstr ""
"from odps.apis.storage_api_v2 import StorageApiClient, ArrowWriter, "
"Compression\n"
"\n"
"client = StorageApiClient(odps, table)\n"
"\n"
"write_resp = client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"client.create_write_stream(session_id, stream_id=0)\n"
"\n"
"stream_writer = client.write_rows_stream(\n"
"    session_id, stream_id=0, record_count=3,\n"
")\n"
"arrow_writer = ArrowWriter(stream_writer, Compression.UNCOMPRESSED)\n"
"arrow_writer.write(batch)\n"
"commit_msg, success = arrow_writer.finish()\n"
"\n"
"client.close_write_stream(session_id, stream_id=0)\n"
"client.commit_write_session(session_id)"

#: ../../source/base-storage-api-v2.rst:532
msgid "Exactly-Once 写入模式"
msgstr "Exactly-Once write mode"

#: ../../source/base-storage-api-v2.rst:534
msgid ""
"Storage API V2 支持 Exactly-Once 语义，确保写入操作的幂等性。启用后，服务端会返回 access_token 和 "
"row_offset，用于重试时保证数据不重复："
msgstr ""
"Storage API V2 supports Exactly-Once semantics, ensuring idempotent write "
"operations. When enabled, the server returns an access_token and row_offset "
"to guarantee no duplicate data on retries:"

#: ../../source/base-storage-api-v2.rst:537
#, python-brace-format
msgid ""
"# 创建写会话\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"# 创建写流，启用 Exactly-Once 模式\n"
"stream_resp = arrow_client.create_write_stream(session_id, stream_id=0)\n"
"access_token = stream_resp.access_token\n"
"\n"
"# 写入数据时传入 access_token\n"
"writer = arrow_client.write_rows_arrow(\n"
"    session_id, stream_id=0, record_count=3,\n"
"    access_token=access_token,\n"
")\n"
"writer.write(batch)\n"
"commit_msg, success = writer.finish()\n"
"\n"
"# 获取 Exactly-Once 模式的写入偏移量\n"
"write_stream_resp = writer.get_write_stream_response()\n"
"if write_stream_resp is not None:\n"
"    print(f\"写入偏移量: {write_stream_resp.exactly_once_row_offset}\")\n"
"\n"
"# 查询写流状态也可获取 access_token 和 row_offset\n"
"stream_status = arrow_client.get_write_stream(\n"
"    session_id, stream_id=0, stream_version=0,\n"
")\n"
"print(f\"最新 schema 版本: {stream_status.latest_schema_version}\")\n"
"print(f\"写入偏移量: {stream_status.row_offset}\")"
msgstr ""
"# Create a write session\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"# Create a write stream with Exactly-Once mode\n"
"stream_resp = arrow_client.create_write_stream(session_id, stream_id=0)\n"
"access_token = stream_resp.access_token\n"
"\n"
"# Pass access_token when writing data\n"
"writer = arrow_client.write_rows_arrow(\n"
"    session_id, stream_id=0, record_count=3,\n"
"    access_token=access_token,\n"
")\n"
"writer.write(batch)\n"
"commit_msg, success = writer.finish()\n"
"\n"
"# Get the write offset in Exactly-Once mode\n"
"write_stream_resp = writer.get_write_stream_response()\n"
"if write_stream_resp is not None:\n"
"    print(f\"Write offset: {write_stream_resp.exactly_once_row_offset}\")\n"
"\n"
"# Query write stream status to get access_token and row_offset\n"
"stream_status = arrow_client.get_write_stream(\n"
"    session_id, stream_id=0, stream_version=0,\n"
")\n"
"print(f\"Latest schema version: {stream_status.latest_schema_version}\")\n"
"print(f\"Write offset: {stream_status.row_offset}\")"

#: ../../source/base-storage-api-v2.rst:569
msgid ""
"Exactly-Once 模式下，写流重试时需要使用上次成功写入返回的 ``row_offset`` 和 ``access_token`` "
"来保证幂等性。"
msgstr ""
"In Exactly-Once mode, when retrying a write stream, you must use the "
"``row_offset`` and ``access_token`` from the last successful write to "
"ensure idempotency."

#: ../../source/base-storage-api-v2.rst:573
msgid "中止写会话"
msgstr "Aborting a write session"

#: ../../source/base-storage-api-v2.rst:575
msgid "如果写入过程中发生错误，可以中止写会话以丢弃所有已上传的数据："
msgstr ""
"If an error occurs during writing, you can abort the write session to "
"discard all uploaded data:"

#: ../../source/base-storage-api-v2.rst:577
msgid ""
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"try:\n"
"    # 写入数据...\n"
"    pass\n"
"except Exception as e:\n"
"    # 发生错误时中止会话\n"
"    arrow_client.abort_write_session(session_id)\n"
"    raise"
msgstr ""
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"\n"
"try:\n"
"    # Write data...\n"
"    pass\n"
"except Exception as e:\n"
"    # Abort the session on error\n"
"    arrow_client.abort_write_session(session_id)\n"
"    raise"

#: ../../source/base-storage-api-v2.rst:591
msgid "查询写会话状态"
msgstr "Querying write session status"

#: ../../source/base-storage-api-v2.rst:593
msgid "可以使用 ``get_write_session`` 方法查看写会话中各流的状态："
msgstr ""
"Use the ``get_write_session`` method to check the status of streams in a "
"write session:"

#: ../../source/base-storage-api-v2.rst:595
#, python-brace-format
msgid ""
"status = arrow_client.get_write_session(session_id)\n"
"if status.streams:\n"
"    for stream_info in status.streams:\n"
"        print(f\"Stream: {stream_info}\")"
msgstr ""
"status = arrow_client.get_write_session(session_id)\n"
"if status.streams:\n"
"    for stream_info in status.streams:\n"
"        print(f\"Stream: {stream_info}\")"

#: ../../source/base-storage-api-v2.rst:602
msgid "也可以使用 ``get_write_stream`` 方法查询单个写流的详细状态："
msgstr "You can also use the ``get_write_stream`` method to query the detailed status of an individual write stream:"

#: ../../source/base-storage-api-v2.rst:604
#, python-brace-format
msgid ""
"stream_status = arrow_client.get_write_stream(\n"
"    session_id, stream_id=0, stream_version=0,\n"
")\n"
"print(f\"流状态: {stream_status.status}\")\n"
"print(f\"已写入记录数: {stream_status.record_count}\")\n"
"print(f\"已写入字节数: {stream_status.byte_size}\")"
msgstr ""
"stream_status = arrow_client.get_write_stream(\n"
"    session_id, stream_id=0, stream_version=0,\n"
")\n"
"print(f\"Stream status: {stream_status.status}\")\n"
"print(f\"Records written: {stream_status.record_count}\")\n"
"print(f\"Bytes written: {stream_status.byte_size}\")"

#: ../../source/base-storage-api-v2.rst:613
msgid "对于事务表（Delta 表），提交写会话时可以指定需要提交的流 ID 和版本："
msgstr ""
"For transactional (Delta) tables, you can specify stream IDs and versions"
" when committing the write session:"

#: ../../source/base-storage-api-v2.rst:615
msgid ""
"arrow_client.commit_write_session(\n"
"    session_id,\n"
"    stream_ids=[\"stream-1\", \"stream-2\"],\n"
"    stream_versions=[1, 1],\n"
")"
msgstr ""
"arrow_client.commit_write_session(\n"
"    session_id,\n"
"    stream_ids=[\"stream-1\", \"stream-2\"],\n"
"    stream_versions=[1, 1],\n"
")"

#: ../../source/base-storage-api-v2.rst:624
msgid "路由令牌与会话亲和性"
msgstr "Route tokens and session affinity"

#: ../../source/base-storage-api-v2.rst:626
msgid "服务端在创建会话和写流时会返回路由令牌（route token），客户端会自动存储并在后续请求中 携带该令牌，确保请求路由到同一节点，提高性能："
msgstr ""
"The server returns a route token when creating sessions and write streams. "
"The client automatically stores and includes this token in subsequent "
"requests, ensuring requests are routed to the same node for better performance:"

#: ../../source/base-storage-api-v2.rst:629
#, python-brace-format
msgid ""
"# 路由令牌会自动从响应中提取并存储\n"
"write_resp = arrow_client.create_write_session()\n"
"print(f\"当前路由令牌: {arrow_client.route_token}\")\n"
"\n"
"# 也可以手动指定 route_token 参数覆盖自动值\n"
"arrow_client.commit_write_session(\n"
"    session_id, route_token=\"your-route-token\",\n"
")"
msgstr ""
"# Route token is automatically extracted from responses and stored\n"
"write_resp = arrow_client.create_write_session()\n"
"print(f\"Current route token: {arrow_client.route_token}\")\n"
"\n"
"# You can also manually specify the route_token parameter to override\n"
"arrow_client.commit_write_session(\n"
"    session_id, route_token=\"your-route-token\",\n"
")"

#: ../../source/base-storage-api-v2.rst:641
msgid "Blob 数据读写"
msgstr "Blob data read/write"

#: ../../source/base-storage-api-v2.rst:643
msgid "Storage API V2 支持 Blob 类型数据的读写。Blob 读写适用于包含 BLOB 列的表 （表格式需为 V2 且开启事务性）。"
msgstr ""
"Storage API V2 supports reading and writing Blob data. Blob read/write "
"applies to tables with BLOB columns (table format must be V2 with "
"transactional mode enabled)."

#: ../../source/base-storage-api-v2.rst:647
msgid "写入 Blob 数据"
msgstr "Writing Blob data"

#: ../../source/base-storage-api-v2.rst:649
msgid "使用 ``write_blob_stream`` 方法以流式方式上传单个 Blob："
msgstr ""
"Use the ``write_blob_stream`` method to upload a single Blob in streaming"
" mode:"

#: ../../source/base-storage-api-v2.rst:651
#, python-brace-format
msgid ""
"# 写入 Blob 数据（默认不压缩，启用 MD5 校验）\n"
"blob_writer = arrow_client.write_blob_stream(\n"
"    session_id, stream_id=0, partition_values=[\"pt=20230101\"],\n"
")\n"
"blob_writer.write(b\"your blob data here\")\n"
"response = blob_writer.finish()\n"
"print(f\"Blob reference: {response.blob_reference}\")"
msgstr ""
"# Write Blob data (no compression by default, MD5 checksum enabled)\n"
"blob_writer = arrow_client.write_blob_stream(\n"
"    session_id, stream_id=0, partition_values=[\"pt=20230101\"],\n"
")\n"
"blob_writer.write(b\"your blob data here\")\n"
"response = blob_writer.finish()\n"
"print(f\"Blob reference: {response.blob_reference}\")"

#: ../../source/base-storage-api-v2.rst:661
msgid "写入时可以指定压缩算法："
msgstr "You can specify a compression algorithm when writing:"

#: ../../source/base-storage-api-v2.rst:663
#, python-brace-format
msgid ""
"from odps.apis.storage_api_v2 import Compression\n"
"\n"
"# 使用 ZSTD 压缩写入 Blob\n"
"blob_writer = arrow_client.write_blob_stream(\n"
"    session_id, stream_id=0, partition_values=[\"pt=20230101\"],\n"
"    compression=Compression.ZSTD,\n"
")\n"
"blob_writer.write(b\"your blob data here\")\n"
"response = blob_writer.finish()"
msgstr ""
"from odps.apis.storage_api_v2 import Compression\n"
"\n"
"# Write Blob with ZSTD compression\n"
"blob_writer = arrow_client.write_blob_stream(\n"
"    session_id, stream_id=0, partition_values=[\"pt=20230101\"],\n"
"    compression=Compression.ZSTD,\n"
")\n"
"blob_writer.write(b\"your blob data here\")\n"
"response = blob_writer.finish()"

#: ../../source/base-storage-api-v2.rst:675
msgid "使用 ``write_blob_batch`` 方法批量上传多个 Blob："
msgstr "Use the ``write_blob_batch`` method to upload multiple Blobs in batch:"

#: ../../source/base-storage-api-v2.rst:677
#, python-brace-format
msgid ""
"from odps.apis.storage_api_v2 import BlobWriteItem, ChecksumType\n"
"\n"
"# 创建 BlobWriteItem 列表\n"
"items = [\n"
"    BlobWriteItem(\n"
"        data=b\"blob data 1\",\n"
"        partition_values=[\"pt=20230101\"],\n"
"        column_index=0,\n"
"        mime_type=\"image/png\",\n"
"        checksum_type=ChecksumType.MD5,\n"
"        distribution_key=\"key1\",\n"
"    ),\n"
"    BlobWriteItem(\n"
"        data=b\"blob data 2\",\n"
"        partition_values=[\"pt=20230101\"],\n"
"        column_index=0,\n"
"    ),\n"
"]\n"
"\n"
"# 批量写入\n"
"response = arrow_client.write_blob_batch(\n"
"    items, session_id=session_id, stream_id=0,\n"
")\n"
"print(f\"Blob references: {response.blob_references}\")"
msgstr ""
"from odps.apis.storage_api_v2 import BlobWriteItem, ChecksumType\n"
"\n"
"# Create a list of BlobWriteItems\n"
"items = [\n"
"    BlobWriteItem(\n"
"        data=b\"blob data 1\",\n"
"        partition_values=[\"pt=20230101\"],\n"
"        column_index=0,\n"
"        mime_type=\"image/png\",\n"
"        checksum_type=ChecksumType.MD5,\n"
"        distribution_key=\"key1\",\n"
"    ),\n"
"    BlobWriteItem(\n"
"        data=b\"blob data 2\",\n"
"        partition_values=[\"pt=20230101\"],\n"
"        column_index=0,\n"
"    ),\n"
"]\n"
"\n"
"# Batch write\n"
"response = arrow_client.write_blob_batch(\n"
"    items, session_id=session_id, stream_id=0,\n"
")\n"
"print(f\"Blob references: {response.blob_references}\")"

#: ../../source/base-storage-api-v2.rst:704
msgid ""
"``BlobWriteItem`` 支持 ``distribution_key`` 参数用于指定分布键， ``checksum_type`` "
"参数支持以下校验类型："
msgstr ""
"``BlobWriteItem`` supports the ``distribution_key`` parameter to specify a "
"distribution key. The ``checksum_type`` parameter supports the following "
"checksum types:"

#: ../../source/base-storage-api-v2.rst:707
msgid "``ChecksumType.NONE`` -- 不校验（默认）"
msgstr "``ChecksumType.NONE`` -- No verification (default)"

#: ../../source/base-storage-api-v2.rst:708
msgid "``ChecksumType.CRC32`` -- CRC32 校验"
msgstr "``ChecksumType.CRC32`` -- CRC32 checksum"

#: ../../source/base-storage-api-v2.rst:709
msgid "``ChecksumType.MD5`` -- MD5 校验"
msgstr "``ChecksumType.MD5`` -- MD5 checksum"

#: ../../source/base-storage-api-v2.rst:712
msgid "读取 Blob 数据"
msgstr "Reading Blob data"

#: ../../source/base-storage-api-v2.rst:714
msgid ""
"使用 ``read_blobs`` 方法通过 Blob 引用下载数据。返回 ``BlobDataIterator`` 迭代器， 每次迭代返回 "
"``(data_bytes, mime_type)`` 元组："
msgstr ""
"Use the ``read_blobs`` method to download data by Blob references. It "
"returns a ``BlobDataIterator`` that yields ``(data_bytes, mime_type)`` "
"tuples:"

#: ../../source/base-storage-api-v2.rst:717
#, python-brace-format
msgid ""
"# 批量读取 Blob\n"
"iterator = arrow_client.read_blobs(blob_references=[\"ref1\", \"ref2\"])\n"
"for data, mime_type in iterator:\n"
"    print(f\"Blob size: {len(data)}, MIME type: {mime_type}\")"
msgstr ""
"# Read Blobs in batch\n"
"iterator = arrow_client.read_blobs(blob_references=[\"ref1\", \"ref2\"])\n"
"for data, mime_type in iterator:\n"
"    print(f\"Blob size: {len(data)}, MIME type: {mime_type}\")"

#: ../../source/base-storage-api-v2.rst:724
msgid "也可以使用 ``stream=True`` 参数获取 ``BlobStreamReader`` 进行流式读取："
msgstr ""
"You can also pass ``stream=True`` to get a ``BlobStreamReader`` for "
"streaming reads:"

#: ../../source/base-storage-api-v2.rst:726
#, python-brace-format
msgid ""
"# 流式读取 Blob\n"
"stream_reader = arrow_client.read_blobs(\n"
"    blob_references=[\"ref1\", \"ref2\"], stream=True,\n"
")\n"
"while stream_reader is not None:\n"
"    chunk = stream_reader.read(4096)  # 每次读取 4KB\n"
"    if not chunk:\n"
"        # 当前 Blob 读取完毕，切换到下一个\n"
"        stream_reader = stream_reader.next()\n"
"    else:\n"
"        # 处理数据块\n"
"        process_chunk(chunk)\n"
"        print(f\"Current blob MIME type: {stream_reader.mime_type}\")"
msgstr ""
"# Stream Blobs\n"
"stream_reader = arrow_client.read_blobs(\n"
"    blob_references=[\"ref1\", \"ref2\"], stream=True,\n"
")\n"
"while stream_reader is not None:\n"
"    chunk = stream_reader.read(4096)  # Read 4KB at a time\n"
"    if not chunk:\n"
"        # Current Blob exhausted, move to the next one\n"
"        stream_reader = stream_reader.next()\n"
"    else:\n"
"        # Process the data chunk\n"
"        process_chunk(chunk)\n"
"        print(f\"Current blob MIME type: {stream_reader.mime_type}\")"

#: ../../source/base-storage-api-v2.rst:742
msgid "读取时可以指定压缩算法："
msgstr "You can specify a compression algorithm when reading:"

#: ../../source/base-storage-api-v2.rst:744
msgid ""
"# 读取使用 ZSTD 压缩的 Blob\n"
"iterator = arrow_client.read_blobs(\n"
"    blob_references=[\"ref1\", \"ref2\"],\n"
"    compression=Compression.ZSTD,\n"
")"
msgstr ""
"# Read Blobs compressed with ZSTD\n"
"iterator = arrow_client.read_blobs(\n"
"    blob_references=[\"ref1\", \"ref2\"],\n"
"    compression=Compression.ZSTD,\n"
")"

#: ../../source/base-storage-api-v2.rst:753
msgid "完整的 Blob 读写示例"
msgstr "Complete Blob read/write example"

#: ../../source/base-storage-api-v2.rst:755
#, python-brace-format
msgid ""
"from odps.apis.storage_api_v2 import (\n"
"    StorageApiArrowClient, BlobWriteItem, ChecksumType,\n"
")\n"
"\n"
"arrow_client = StorageApiArrowClient(odps, blob_table)\n"
"\n"
"# 创建写会话和写流\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"arrow_client.create_write_stream(session_id, stream_id=0)\n"
"\n"
"# 写入 Blob 数据\n"
"items = [\n"
"    BlobWriteItem(data=b\"hello world\", partition_values=[\"pt=test\"]),"
"\n"
"    BlobWriteItem(data=b\"foo bar\", partition_values=[\"pt=test\"]),\n"
"]\n"
"write_resp = arrow_client.write_blob_batch(\n"
"    items, session_id=session_id, stream_id=0,\n"
")\n"
"blob_refs = write_resp.blob_references\n"
"\n"
"# 关闭写流并提交会话\n"
"arrow_client.close_write_stream(session_id, stream_id=0)\n"
"arrow_client.commit_write_session(session_id)\n"
"\n"
"# 读取 Blob 数据\n"
"iterator = arrow_client.read_blobs(blob_references=blob_refs)\n"
"for data, mime_type in iterator:\n"
"    print(f\"Data: {data!r}, MIME type: {mime_type}\")"
msgstr ""
"from odps.apis.storage_api_v2 import (\n"
"    StorageApiArrowClient, BlobWriteItem, ChecksumType,\n"
")\n"
"\n"
"arrow_client = StorageApiArrowClient(odps, blob_table)\n"
"\n"
"# Create write session and stream\n"
"write_resp = arrow_client.create_write_session()\n"
"session_id = write_resp.session_id\n"
"arrow_client.create_write_stream(session_id, stream_id=0)\n"
"\n"
"# Write Blob data\n"
"items = [\n"
"    BlobWriteItem(data=b\"hello world\", partition_values=[\"pt=test\"]),"
"\n"
"    BlobWriteItem(data=b\"foo bar\", partition_values=[\"pt=test\"]),\n"
"]\n"
"write_resp = arrow_client.write_blob_batch(\n"
"    items, session_id=session_id, stream_id=0,\n"
")\n"
"blob_refs = write_resp.blob_references\n"
"\n"
"# Close the write stream and commit the session\n"
"arrow_client.close_write_stream(session_id, stream_id=0)\n"
"arrow_client.commit_write_session(session_id)\n"
"\n"
"# Read Blob data\n"
"iterator = arrow_client.read_blobs(blob_references=blob_refs)\n"
"for data, mime_type in iterator:\n"
"    print(f\"Data: {data!r}, MIME type: {mime_type}\")"

#: ../../source/base-storage-api-v2.rst:788
msgid "压缩选项"
msgstr "Compression options"

#: ../../source/base-storage-api-v2.rst:790
msgid "Storage API V2 内置支持以下压缩算法："
msgstr "Storage API V2 supports the following compression algorithms:"

#: ../../source/base-storage-api-v2.rst:792
msgid "``Compression.UNCOMPRESSED`` -- 不压缩（默认）"
msgstr "``Compression.UNCOMPRESSED`` -- No compression (default)"

#: ../../source/base-storage-api-v2.rst:793
msgid "``Compression.ZSTD`` -- ZSTD 压缩（需要安装 ``zstandard`` 库）"
msgstr "``Compression.ZSTD`` -- ZSTD compression (requires ``zstandard`` library)"

#: ../../source/base-storage-api-v2.rst:794
msgid "``Compression.LZ4_FRAME`` -- LZ4 帧格式压缩（需要安装 ``lz4`` 库）"
msgstr ""
"``Compression.LZ4_FRAME`` -- LZ4 frame format compression (requires "
"``lz4`` library)"

#: ../../source/base-storage-api-v2.rst:796
msgid "默认情况下，读写操作不使用压缩（``Compression.UNCOMPRESSED``）。可以在读取和写入时指定压缩算法："
msgstr ""
"By default, read/write operations use no compression "
"(``Compression.UNCOMPRESSED``). You can specify a compression algorithm "
"when reading and writing:"

#: ../../source/base-storage-api-v2.rst:798
msgid ""
"from odps.apis.storage_api_v2 import Compression\n"
"\n"
"# 写入时使用 ZSTD 压缩\n"
"writer = arrow_client.write_rows_arrow(\n"
"    session_id, stream_id=0, record_count=100,\n"
"    compression=Compression.ZSTD,\n"
")\n"
"\n"
"# 读取时使用 LZ4 帧格式解压\n"
"reader = arrow_client.read_rows_arrow(\n"
"    session_id, split_index=0,\n"
"    compression=Compression.LZ4_FRAME,\n"
")"
msgstr ""
"from odps.apis.storage_api_v2 import Compression\n"
"\n"
"# Use ZSTD compression when writing\n"
"writer = arrow_client.write_rows_arrow(\n"
"    session_id, stream_id=0, record_count=100,\n"
"    compression=Compression.ZSTD,\n"
")\n"
"\n"
"# Use LZ4 frame decompression when reading\n"
"reader = arrow_client.read_rows_arrow(\n"
"    session_id, split_index=0,\n"
"    compression=Compression.LZ4_FRAME,\n"
")"

#: ../../source/base-storage-api-v2.rst:815
msgid "数据过滤"
msgstr "Data filtering"

#: ../../source/base-storage-api-v2.rst:817
msgid "Storage API V2 支持在创建读会话时通过 ``filter_predicate`` 参数指定过滤条件，减少网络传输数据量："
msgstr ""
"Storage API V2 supports specifying filter conditions via the "
"``filter_predicate`` parameter when creating a read session, reducing "
"network data transfer:"

#: ../../source/base-storage-api-v2.rst:819
msgid ""
"# 使用过滤谓词\n"
"read_resp = arrow_client.create_read_session(\n"
"    filter_predicate=\"id > 100 AND name = 'test'\",\n"
")"
msgstr ""
"# Use a filter predicate\n"
"read_resp = arrow_client.create_read_session(\n"
"    filter_predicate=\"id > 100 AND name = 'test'\",\n"
")"

#: ../../source/base-storage-api-v2.rst:826
msgid "如果谓词下推失败，可以设置 ``filter_predicate_fallback=True`` 回退到服务端过滤："
msgstr ""
"If predicate pushdown fails, you can set "
"``filter_predicate_fallback=True`` to fall back to server-side filtering:"

#: ../../source/base-storage-api-v2.rst:828
msgid ""
"read_resp = arrow_client.create_read_session(\n"
"    filter_predicate=\"id > 100\",\n"
"    filter_predicate_fallback=True,\n"
")"
msgstr ""
"read_resp = arrow_client.create_read_session(\n"
"    filter_predicate=\"id > 100\",\n"
"    filter_predicate_fallback=True,\n"
")"

#: ../../source/base-storage-api-v2.rst:835
msgid "创建读会话时还可以通过 ``split_max_file_num`` 参数限制分片中的最大文件数："
msgstr "You can also limit the maximum number of files per split with the ``split_max_file_num`` parameter when creating a read session:"

#: ../../source/base-storage-api-v2.rst:837
msgid ""
"read_resp = arrow_client.create_read_session(\n"
"    split_max_file_num=1000,\n"
")"
msgstr ""
"read_resp = arrow_client.create_read_session(\n"
"    split_max_file_num=1000,\n"
")"

#: ../../source/base-storage-api-v2.rst:844
msgid "Arrow 格式选项"
msgstr "Arrow format options"

#: ../../source/base-storage-api-v2.rst:846
msgid "创建读会话时可以通过 ``arrow_options`` 参数控制 Arrow 格式的精度："
msgstr ""
"When creating a read session, you can control Arrow format precision via "
"the ``arrow_options`` parameter:"

#: ../../source/base-storage-api-v2.rst:848
msgid ""
"from odps.apis.storage_api_v2 import ArrowOptions\n"
"\n"
"# 设置时间戳精度为微秒\n"
"arrow_opts = ArrowOptions()\n"
"arrow_opts.timestamp_unit = ArrowOptions.TimestampUnit.MICRO\n"
"arrow_opts.date_time_unit = ArrowOptions.TimestampUnit.MILLI\n"
"\n"
"read_resp = arrow_client.create_read_session(\n"
"    arrow_options=arrow_opts,\n"
")"
msgstr ""
"from odps.apis.storage_api_v2 import ArrowOptions\n"
"\n"
"# Set timestamp precision to microseconds\n"
"arrow_opts = ArrowOptions()\n"
"arrow_opts.timestamp_unit = ArrowOptions.TimestampUnit.MICRO\n"
"arrow_opts.date_time_unit = ArrowOptions.TimestampUnit.MILLI\n"
"\n"
"read_resp = arrow_client.create_read_session(\n"
"    arrow_options=arrow_opts,\n"
")"

#: ../../source/base-storage-api-v2.rst:861
msgid "ArrowOptions 支持的精度选项："
msgstr "Precision options supported by ArrowOptions:"

#: ../../source/base-storage-api-v2.rst:863
msgid "``TimestampUnit.SECOND`` -- 秒"
msgstr "``TimestampUnit.SECOND`` -- Seconds"

#: ../../source/base-storage-api-v2.rst:864
msgid "``TimestampUnit.MILLI`` -- 毫秒"
msgstr "``TimestampUnit.MILLI`` -- Milliseconds"

#: ../../source/base-storage-api-v2.rst:865
msgid "``TimestampUnit.MICRO`` -- 微秒"
msgstr "``TimestampUnit.MICRO`` -- Microseconds"

#: ../../source/base-storage-api-v2.rst:866
msgid "``TimestampUnit.NANO`` -- 纳秒（默认）"
msgstr "``TimestampUnit.NANO`` -- Nanoseconds (default)"

#: ../../source/base-storage-api-v2.rst:869
msgid "SplitOptions 分片选项"
msgstr "SplitOptions"

#: ../../source/base-storage-api-v2.rst:871
msgid "创建读会话时可以通过 ``split_options`` 参数控制数据的分片方式："
msgstr ""
"When creating a read session, you can control how data is split via the "
"``split_options`` parameter:"

#: ../../source/base-storage-api-v2.rst:873
msgid ""
"from odps.apis.storage_api_v2 import SplitOptions\n"
"\n"
"# 按大小分片（默认），每个分片 256MB\n"
"split_opts = SplitOptions()\n"
"\n"
"# 按并行度分片，创建指定数量的分片\n"
"split_opts = SplitOptions()\n"
"split_opts.split_mode = SplitOptions.SplitMode.PARALLELISM\n"
"split_opts.split_number = 10\n"
"\n"
"# 按行偏移分片\n"
"split_opts = SplitOptions()\n"
"split_opts.split_mode = SplitOptions.SplitMode.ROW_OFFSET\n"
"split_opts.split_number = 100000  # 每个分片 10 万行\n"
"\n"
"# 按 Bucket ID 分片（适用于聚簇表）\n"
"split_opts = SplitOptions()\n"
"split_opts.split_mode = SplitOptions.SplitMode.BUCKET\n"
"\n"
"# 是否跨分区分片（默认为 True）\n"
"split_opts = SplitOptions()\n"
"split_opts.cross_partition = False"
msgstr ""
"from odps.apis.storage_api_v2 import SplitOptions\n"
"\n"
"# Split by size (default), 256MB per split\n"
"split_opts = SplitOptions()\n"
"\n"
"# Split by parallelism, create a specified number of splits\n"
"split_opts = SplitOptions()\n"
"split_opts.split_mode = SplitOptions.SplitMode.PARALLELISM\n"
"split_opts.split_number = 10\n"
"\n"
"# Split by row offset\n"
"split_opts = SplitOptions()\n"
"split_opts.split_mode = SplitOptions.SplitMode.ROW_OFFSET\n"
"split_opts.split_number = 100000  # 100k rows per split\n"
"\n"
"# Split by Bucket ID (for clustered tables)\n"
"split_opts = SplitOptions()\n"
"split_opts.split_mode = SplitOptions.SplitMode.BUCKET\n"
"\n"
"# Whether to split across partitions (default is True)\n"
"split_opts = SplitOptions()\n"
"split_opts.cross_partition = False"

#: ../../source/base-storage-api-v2.rst:898
