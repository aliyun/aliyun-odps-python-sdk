#: ../../source/base-storage-api-v2.rst:152
msgid "使用 Arrow 格式读取数据"
msgstr "Reading data in Arrow format"

#: ../../source/base-storage-api-v2.rst:154
msgid ""
"使用 ``StorageApiArrowClient`` 的 ``read_rows_arrow`` 方法可以直接读取为 Arrow "
"RecordBatch："
msgstr ""
"Use the ``read_rows_arrow`` method of ``StorageApiArrowClient`` to read "
"data directly as Arrow RecordBatches:"

#: ../../source/base-storage-api-v2.rst:156
msgid ""
"import pyarrow as pa\n"
"\n"
"read_resp = arrow_client.create_read_session()\n"
"\n"
"# 遍历所有分片读取数据\n"
"for split_index in range(read_resp.splits_count):\n"
"    reader = arrow_client.read_rows_arrow(\n"
"        read_resp.session_id, split_index=split_index\n"
"    )\n"
"    while True:\n"
"        batch = reader.read()\n"
"        if batch is None:\n"
"            break\n"
"        df = batch.to_pandas()\n"
"        # 处理 DataFrame"
msgstr ""
"import pyarrow as pa\n"
"\n"
"read_resp = arrow_client.create_read_session()\n"
"\n"
"# Iterate over all splits to read data\n"
"for split_index in range(read_resp.splits_count):\n"
"    reader = arrow_client.read_rows_arrow(\n"
"        read_resp.session_id, split_index=split_index\n"
"    )\n"
"    while True:\n"
"        batch = reader.read()\n"
"        if batch is None:\n"
"            break\n"
"        df = batch.to_pandas()\n"
"        # Process the DataFrame"

